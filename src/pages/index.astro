    <script is:inline>
    window.addEventListener('load', function() {
        var counted = false;
        var section = document.querySelector('.count-up');
        if (!section) return;
        var secEl = section.closest('section');

        function animateCount(el) {
            var text = el.getAttribute('data-value');
            var suffix = el.getAttribute('data-suffix') || '';
            var useComma = el.hasAttribute('data-format');
            var isStatic = /[^0-9]/.test(text) && !useComma; // e.g. "24/7"
            var duration = 3000;
            var startTime = null;

            if (isStatic) {
                // Per-digit animation for mixed text like "24/7"
                var chars = text.split('');
                var digitTargets = [];
                chars.forEach(function(ch, idx) {
                    if (/\d/.test(ch)) digitTargets.push({idx: idx, target: parseInt(ch)});
                });
                function stepStatic(ts) {
                    if (!startTime) startTime = ts;
                    var progress = Math.min((ts - startTime) / duration, 1);
                    var eased = 1 - Math.pow(1 - progress, 3);
                    var result = chars.slice();
                    digitTargets.forEach(function(d) {
                        result[d.idx] = String(Math.round(eased * d.target));
                    });
                    el.textContent = result.join('') + suffix;
                    if (progress < 1) requestAnimationFrame(stepStatic);
                    else el.textContent = text + suffix;
                }
                el.textContent = chars.map(function(ch) { return /\d/.test(ch) ? '0' : ch; }).join('') + suffix;
                requestAnimationFrame(stepStatic);
            } else {
                // Smooth single-number count for integers like 10000, 90
                var target = parseInt(text);
                function stepNum(ts) {
                    if (!startTime) startTime = ts;
                    var progress = Math.min((ts - startTime) / duration, 1);
                    var eased = 1 - Math.pow(1 - progress, 3);
                    var current = Math.round(eased * target);
                    el.textContent = (useComma ? current.toLocaleString() : String(current)) + suffix;
                    if (progress < 1) requestAnimationFrame(stepNum);
                    else el.textContent = (useComma ? target.toLocaleString() : String(target)) + suffix;
                }
                el.textContent = '0' + suffix;
                requestAnimationFrame(stepNum);
            }
        }

        function isInViewport(el) {
            var r = el.getBoundingClientRect();
            return r.top < window.innerHeight && r.bottom > 0;
        }

        // If already visible on load, skip animation - keep final values
        if (isInViewport(secEl)) {
            counted = true;
            return;
        }

        var observer = new IntersectionObserver(function(entries) {
            entries.forEach(function(entry) {
                if (entry.isIntersecting && !counted) {
                    counted = true;
                    document.querySelectorAll('.count-up').forEach(animateCount);
                    observer.disconnect();
                }
            });
        }, { threshold: 0.3 });
        observer.observe(secEl);
    });
    </script>
</section>

