<!-- ============ INDUSTRIES ============ -->
<section class="py-20" x-data="{ scrollIndustry(dir) { var el = $refs.industrySlider; el.scrollBy({ left: dir * 383, behavior: 'smooth' }); } }">
    <div class="max-w-[1140px] mx-auto px-3">
        <!-- Header: H2 left, Arrows right -->
        <div class="flex items-center justify-between mb-16">
            <h2 class="text-[36px] font-semibold text-[#1f2937] leading-[39.6px]">Tailored AI-Powered Solutions<br/>for Every Service Industry</h2>
            <div class="flex gap-5 flex-shrink-0">
                <button @click="scrollIndustry(-1)" class="w-14 h-14 rounded-full border border-gray-200 flex items-center justify-center hover:bg-gray-50 transition">
                    <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </button>
                <button @click="scrollIndustry(1)" class="w-14 h-14 rounded-full border border-gray-200 flex items-center justify-center hover:bg-gray-50 transition">
                    <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </button>
            </div>
        </div>

        <!-- Slider -->
        <div class="overflow-hidden">
            <div x-ref="industrySlider" class="flex gap-8 overflow-x-auto hide-scrollbar" style="scroll-snap-type: x mandatory;">
                {industries.map(ind => (
                    <IndustryCard href={ind.href} img={ind.img} alt={ind.alt} title={ind.title} description={ind.description} />
                ))}
            </div>
        </div>
    </div>
</section>

<!-- ============ TESTIMONIALS ============ -->
<section class="py-20" x-data="{ activeTestimonial: 0, testimonials: [
    { name: 'Tracey Franco', company: 'Finance Corp', avatar: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68f0e493101b0407cf1a716c_68d6857aef3f46c0a87919e7_finance.png', quote: 'I\'ve been using Sophiie AI since January 2025, and I am beyond impressed with its capabilities. The call quality, the intelligence, and the way Sophiie understands and responds are simply top-notch. It has significantly streamlined my workflow, handling calls with precision and professionalism.' },
    { name: 'Moira Scott', company: 'Your Local Termite and Pest Control', avatar: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68f0e4c61cb9944ec2ebcf2e_68d6857abf8c0e239b7d9b28_pest-control.png', quote: 'Sophiie has been an absolute game-changer for our pest control business! For the past month, this digital assistant has seamlessly integrated into our call handling process, ensuring we never miss a potential customer.' },
    { name: 'Chris Keast', company: 'Keast Blinds', avatar: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68f0e4fa8c3d167cb56c715c_68d6857aef3f46c0a8791a11_keast.png', quote: 'Great product, super handy if you\'re a busy small business owner like me, not only are calls answered but the clients name and needs are listed so when you finish your task you can contact the client back with everything they need to progress forward.' }
] }">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="flex flex-col lg:flex-row items-center">
            <!-- Left: Testimonial Slider -->
            <div class="lg:w-[47.5%] mb-10 lg:mb-0">
                <!-- Stars -->
                <img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68d5397a17e3ca3571f7f958_five-star.svg" alt="5 stars" class="w-[114px] h-5 mb-[15px]"/>

                <!-- Quote -->
                <p class="text-[30px] font-normal text-[#182230] leading-[39px] mb-2.5" x-text="testimonials[activeTestimonial].quote"></p>

                <!-- Client -->
                <div class="flex items-center gap-3 mt-[47px]">
                    <img :src="testimonials[activeTestimonial].avatar" :alt="testimonials[activeTestimonial].name" class="w-[54px] h-[54px] rounded-full object-cover"/>
                    <div>
                        <div class="text-2xl font-medium text-[#182230]" x-text="testimonials[activeTestimonial].name"></div>
                        <p class="text-xl text-[#182230]" x-text="testimonials[activeTestimonial].company"></p>
                    </div>
                </div>

                <!-- Arrows -->
                <div class="flex gap-5 mt-8">
                    <button @click="activeTestimonial = activeTestimonial === 0 ? testimonials.length - 1 : activeTestimonial - 1" class="w-14 h-14 rounded-full border border-gray-200 flex items-center justify-center hover:bg-gray-50 transition">
                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </button>
                    <button @click="activeTestimonial = activeTestimonial === testimonials.length - 1 ? 0 : activeTestimonial + 1" class="w-14 h-14 rounded-full border border-gray-200 flex items-center justify-center hover:bg-gray-50 transition">
                        <svg class="w-4 h-4 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                    </button>
                </div>
            </div>

            <!-- Right: Image -->
            <div class="lg:w-[52.5%]">
                <img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68d5397af9266dfacc8d0d70_testimonials-rgt-img.webp" alt="Sophiie testimonials" class="w-full"/>
            </div>
        </div>
    </div>
</section>

<!-- ============ BUILD TRUST ============ -->
