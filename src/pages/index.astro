                    <div class="count-up text-[50px] font-semibold text-[#36a5e1] leading-[50px] mb-[21px]" data-value="24/7">24/7</div>
                    <h3 class="text-2xl font-semibold text-[#181d27] leading-[28.8px] mb-2.5">Availability</h3>
