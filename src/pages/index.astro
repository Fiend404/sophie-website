---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import IndustryCard from '../components/IndustryCard.astro';
import FromTheBlog from '../components/FromTheBlog.astro';
import allArticles from '../data/articles.json';

const newsArticles = allArticles.slice(0, 2);

const industries = [
    { href: '/trade/electricians', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/6924501205a9a3c71accb77a_electri-img.jpg', alt: 'Electricians', title: 'AI Tools for Electricians', description: 'AI solutions that help electricians respond instantly to urgent fault calls, automate scheduling, and capture more high-value jobs.' },
    { href: '/trade/plumber', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/69254715b77c21d1739f3e5e_image%20(82).jpg', alt: 'Plumbers', title: 'AI for Plumbers', description: 'AI for plumbers that captures emergency calls instantly, automates job scheduling, and helps you secure more work.' },
    { href: '/trade/air-conditioning-hvac', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/692466d89b4cc953fd32bdc3_air-conditionar-card.jpg', alt: 'HVAC', title: 'AI for HVAC Business', description: 'AI tools that help HVAC technicians answer calls instantly, manage bookings, and respond faster to urgent jobs.' },
    { href: '/trade/landscaping', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/69258289d9b6ad65ad8cca95_image%20-%202025-11-25T154843.501.jpg', alt: 'Landscaping', title: 'AI Tools for Landscaping', description: 'AI solutions that help landscapers secure more bookings, manage scheduling, and respond faster to client inquiries.' },
    { href: '/trade/carpenters', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/692562bad17a7cc08013b320_image%20-%202025-11-25T133258.910.jpg', alt: 'Carpenters', title: 'AI Tools & Solutions for Carpenters', description: 'AI solutions designed to help carpenters automate calls, manage bookings, and stay organised while taking on more high-value jobs.' },
    { href: '/trade/cleaners', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/6925676781684d98b04b9155_image%20-%202025-11-25T135256.583.jpg', alt: 'Cleaners', title: 'AI for Cleaning Business', description: 'AI tools that help cleaning businesses secure more bookings, automate inquiries, and stay organised with faster job scheduling.' },
    { href: '/trade/professional-painters', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/69258bd0c7a06d185eb6ad19_image%20-%202025-11-25T162819.191.jpg', alt: 'Painters', title: 'AI for Painters', description: 'AI-powered solutions that help painters manage calls, schedule jobs faster, and stay fully booked with less admin.' },
    { href: '/trade/roofing', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/692571b841fadfa837a80726_image%20-%202025-11-25T143658.887.jpg', alt: 'Roofing', title: 'AI Tools for Roofing Companies', description: 'AI tools that help roofing contractors capture urgent calls, book inspections faster, and streamline job management.' },
    { href: '/trade/concreting', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/69256f29d72ae105a9d65797_image%20-%202025-11-25T142602.642.jpg', alt: 'Concreting', title: 'AI Tools for Concrete Specialists', description: 'AI for concreters that automates calls, manages schedules, and helps you secure more jobs without the admin overload.' },
    { href: '/trade/fencing', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/6925744f7078bc023ebc9f07_image%20-%202025-11-25T144758.679.jpg', alt: 'Fencing', title: 'AI Tools for Fencing Contractors', description: 'AI-powered tools that help fencing contractors handle inquiries faster, streamline quotes, and keep projects on schedule.' },
    { href: '/trade/fire-services', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/6925773f4abf5eccfa8847d9_image%20-%202025-11-25T150034.599.jpg', alt: 'Fire Services', title: 'AI Tools for Fire Service Ops', description: 'AI tools that support fire service contractors with instant call answering, job scheduling, and improved compliance workflows.' },
    { href: '/trade/flooring', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/69257a3d7078bc023ebebbab_image%20-%202025-11-25T151316.373.jpg', alt: 'Flooring', title: 'AI Tools for Flooring Specialists', description: 'AI that helps flooring specialists manage client inquiries, book jobs faster, and streamline operations from quote to installation.' },
    { href: '/trade/handyman-property-maintenance', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/69257df26e511284e6f82313_image%20-%202025-11-25T152908.832.jpg', alt: 'Handyman', title: 'AI Receptionist for Handyman Services', description: 'AI tools for handymen and property maintenance pros to automate calls, capture more jobs, and simplify scheduling.' },
    { href: '/trade/plastering', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/69258504e86301a387ba48f6_image%20-%202025-11-25T155918.380.jpg', alt: 'Plasterers', title: 'AI tools for Plasterers', description: 'AI tools for plasterers to handle calls, manage bookings, and keep jobs running smoothly without admin delays.' },
    { href: '/trade/pool-maintenance', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/69258905e5e2a020c6b73d46_image%20-%202025-11-25T161623.803.jpg', alt: 'Pool Cleaners', title: 'AI Tools for Pool Cleaners', description: 'AI tools that help pool maintenance specialists automate client communication, streamline bookings, and manage recurring jobs.' },
    { href: '/trade/bricklaying', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/69255ae4c797f749c232061f_image%20-%202025-11-25T125933.237.jpg', alt: 'Bricklaying', title: 'AI for Bricklaying Contractors', description: 'Boost your bricklaying business with AI that handles calls, scheduling, quotes, and job management.' },
    { href: '/trade/arborist', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/6925539e8029f84e594d70ad_image%20(91).jpg', alt: 'Arborists', title: 'AI Tools & Solutions for Arborists', description: 'AI tools that help arborists manage bookings, answer calls instantly, and schedule tree work faster.' },
    { href: '/trade/builders-job', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/69255e14f449e04a623a42c4_image%20-%202025-11-25T131242.057.jpg', alt: 'Builders', title: 'AI for Builders', description: 'AI-powered tools that help builders streamline calls, manage job schedules, and stay responsive to clients.' },
];

---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>AI Virtual Receptionist Australia | Sophiie AI</title>
    <meta name="description" content="Sophiie is the best AI virtual receptionist in Australia. Streamline admin, answer calls instantly, and book jobs 24/7 for your service-business."/>

    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>

    <script is:inline defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Geist', 'Inter', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            50: '#eef8ff',
                            100: '#d9efff',
                            light: '#9adcff',
                            DEFAULT: '#36a5e1',
                            dark: '#2b84b4',
                            navy: '#081245'
                        }
                    },
                    animation: {
                        'shimmer': 'shimmer 5s linear infinite',
                        'float-y': 'float-y 3s ease-in-out infinite',
                        'pulse-glow': 'pulse-glow 2s cubic-bezier(0.4, 0, 0.6, 1) infinite',
                    },
                    keyframes: {
                        'shimmer': {
                            '0%': { backgroundPosition: '200% center' },
                            '100%': { backgroundPosition: '-200% center' },
                        },
                        'float-y': {
                            '0%, 100%': { transform: 'translateY(0)' },
                            '50%': { transform: 'translateY(-10px)' },
                        },
                        'pulse-glow': {
                            '0%, 100%': { opacity: 1 },
                            '50%': { opacity: 0.5 },
                        }
                    }
                }
            }
        }
    </script>

    <style is:global>
        [x-cloak] { display: none !important; }
        .bnr-not-txt {
            color: #44aee6;
            background-image: url('https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/69b4053695f05f8fbd37cdc5_h1-shape.svg');
            background-repeat: no-repeat;
            background-position: bottom center;
            background-size: 100% auto;
            padding-bottom: 4px;
        }
        .text-gradient-blue {
            background: linear-gradient(245.38deg, #36a5e1 29.35%, #36a5e1 39.7%, #36a5e1 44.84%, #36a5e1 48.8%, #36a5e1 64.16%, #9adcff 70.27%, #36a5e1 73.47%);
            background-size: 200% auto;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shimmer 5s linear infinite;
        }
        .text-gradient-navy {
            background: linear-gradient(90deg, #081245 0%, #081245 40%, #99dbff 50%, #081245 60%, #081245 100%);
            background-size: 300% 100%;
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            animation: shimmer-navy 5s linear infinite;
        }
        @keyframes shimmer-navy {
            0% { background-position: 100% center; }
            100% { background-position: -100% center; }
        }
        @keyframes shimmer {
            0% { background-position: 200% center; }
            100% { background-position: -200% center; }
        }
        .banner-section-bg {
            background: linear-gradient(177deg, #f2f6f9, #bee2ff 80%, #c1e3fe 70%, #afdfff);
        }
        .banner-gradient {
            background: linear-gradient(137deg,
                rgba(255,255,255,0.4) -0.46%,
                rgba(183,230,255,0.4) 29.09%,
                rgba(255,255,255,0.4) 44.85%,
                rgba(154,220,255,0.4) 57.17%,
                rgba(54,165,225,0.4) 67.51%,
                rgba(154,220,255,0.4) 82.78%,
                rgba(255,255,255,0.4) 98.05%);
        }
        .banner-lwr {
            background-color: #57ace5;
            background-image: linear-gradient(40deg, transparent 0% 40%, #a9e0fe 50%, transparent 60% 100%);
            background-size: 200% 100%;
            animation: shine-border 5s linear infinite;
        }
        @keyframes shine-border {
            0%, 10% { background-position: -1000px; }
            100% { background-position: 1000px; }
        }
        .hide-scrollbar::-webkit-scrollbar { display: none; }
        .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        .nav-dropdown {
            position: static;
        }
        .nav-dropdown .nav-dropdown-menu {
            display: block;
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
            transition: 0.3s;
            position: absolute;
            top: 100%;
            left: 0;
            right: 0;
            padding-top: 30px;
        }
        .nav-dropdown:hover .nav-dropdown-menu {
            opacity: 1;
            visibility: visible;
            pointer-events: auto;
        }
        .nav-dropdown:hover .nav-dropdown-arrow {
            transform: rotate(180deg);
        }
        .nav-dropdown-arrow {
            transition: transform 0.3s ease-in-out;
        }
        .industry-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 50%;
            background: linear-gradient(transparent 0%, rgba(0,0,0,0.6) 100%);
            pointer-events: none;
        }
    </style>
</head>
<body class="font-sans text-gray-800 antialiased bg-slate-50 overflow-x-hidden" x-data="{ mobileMenuOpen: false, scrolled: false }" @scroll.window="scrolled = (window.scrollY > 20)">

<Header />

<!-- ============ HERO ============ -->
<section class="relative pt-[130px] pb-0 overflow-hidden banner-section-bg">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <!-- Badge -->
        <div class="relative inline-block bg-[#dbf3ff] rounded-[50px] pl-[30px] pr-[18px] py-[7.5px] mb-9 text-sm font-medium text-[#196d9a] leading-[21px]">
            <span class="absolute left-[15px] top-[18px] w-2 h-2 bg-green-400 rounded-full"></span>
            The AI Office Manager for Trades &amp; Services
        </div>

        <!-- Headline -->
        <h1 class="text-[40px] sm:text-[50px] md:text-[60px] font-bold leading-[66px] mb-2.5 text-[#475467]">
            <span class="bnr-not-txt">Not</span> <span class="text-gradient-blue">Just an AI Receptionist</span><br/>
            <span class="text-gradient-navy">Your Entire Front Office!</span>
        </h1>

        <p class="max-w-[584px] mx-auto text-base text-[#182230] mb-2.5 leading-6">
            Sophiie answers calls, books jobs, send quotes &amp; invoices, smart schedules, dispatches your team, manages jobs and follows up with customers.
        </p>

        <!-- Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-3 pt-[23px]">
            <a href="https://app.sophiie.ai/onboarding" class="inline-flex items-center justify-center px-[26px] py-[15px] border border-[rgba(58,165,223,0.3)] text-[#2b84b4] font-semibold rounded-[10px] transition-all duration-300 hover:bg-[#2b84b4] hover:text-white text-base w-full sm:w-auto">
                Get Started
            </a>
            <a href="/free-demo-alt" class="inline-flex items-center justify-center px-5 py-[14.5px] bg-[#2b84b4] text-white font-semibold rounded-[10px] transition-all duration-300 hover:bg-brand-dark hover:shadow-lg text-base w-full sm:w-auto">
                Chat to Sophiie
            </a>
        </div>

        <div class="flex items-center justify-center gap-5 mt-[27px] text-sm text-[#6b7280]">
            <span>No credit card needed</span>
            <span>307k+ calls answered</span>
        </div>

        <!-- Hero Image -->
        <div class="mt-12 relative max-w-5xl mx-auto">
            <!-- Outer gradient border -->
            <div class="banner-gradient rounded-[30px_30px_0_0] p-5 pb-0">
                <!-- Inner shimmer bar -->
                <div class="banner-lwr rounded-[30px_30px_0_0] p-[25px_20px_0]">
                    <img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68d2a88c6dcf5db3f99ca173_banner-img.webp" alt="Sophiie AI Dashboard" class="w-full h-auto rounded-t-2xl"/>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============ RECEIVE A PHONE CALL ============ -->
<section class="pt-24 pb-0">
    <div class="max-w-[1140px] mx-auto px-3 relative">
        <!-- Background image -->
        <div class="absolute inset-0 overflow-hidden" style="z-index: 0;">
            <img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68d5100fa58204b249907193_received-frm-call-bg.webp" alt="" class="w-full h-full object-cover"/>
        </div>
        <div class="max-w-[1003px] mx-auto flex flex-col lg:flex-row items-center relative" style="z-index: 1;">
            <!-- Left: Form Card -->
            <div class="lg:w-1/2 py-16 pr-0 lg:pr-4">
                <!-- Blue outer wrapper -->
                <div class="banner-lwr rounded-[28px] p-3">
                    <!-- White inner card -->
                    <div class="bg-white rounded-[28px]">
                        <div class="pt-[30px] px-5 pb-5">
                            <!-- H2 inside card -->
                            <h2 class="text-[36px] font-semibold text-[#182230] leading-[39.6px] mb-6">
                                Receive a phone call<br/>from <span class="text-gradient-blue">Sophiie</span>
                            </h2>

                            <form class="space-y-4">
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-base font-normal text-[#182230] mb-1.5">First Name<span class="text-red-500">*</span></label>
                                        <input type="text" class="w-full h-11 px-3 py-2 bg-gray-50 border border-[#d1d5db] rounded-lg text-sm text-[#333] focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition" required/>
                                    </div>
                                    <div>
                                        <label class="block text-base font-normal text-[#182230] mb-1.5">Last Name<span class="text-red-500">*</span></label>
                                        <input type="text" class="w-full h-11 px-3 py-2 bg-gray-50 border border-[#d1d5db] rounded-lg text-sm text-[#333] focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition" required/>
                                    </div>
                                </div>
                                <div class="grid grid-cols-2 gap-4">
                                    <div>
                                        <label class="block text-base font-normal text-[#182230] mb-1.5">Email<span class="text-red-500">*</span></label>
                                        <input type="email" placeholder="Enter your email" class="w-full h-11 px-3 py-2 bg-gray-50 border border-[#d1d5db] rounded-lg text-sm text-[#333] focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition" required/>
                                    </div>
                                    <div>
                                        <label class="block text-base font-normal text-[#182230] mb-1.5">Phone Number<span class="text-red-500">*</span></label>
                                        <div class="flex h-11 border border-[#d1d5db] rounded-lg overflow-hidden bg-gray-50">
                                            <div class="flex items-center gap-1 px-2 border-r border-[#d1d5db] bg-white text-sm">
                                                <span>🇦🇺</span>
                                                <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                                            </div>
                                            <input type="tel" placeholder="+61" class="flex-1 px-3 py-2 bg-gray-50 text-sm text-[#333] outline-none" required/>
                                        </div>
                                    </div>
                                </div>
                                <div>
                                    <label class="block text-base font-normal text-[#182230] mb-1.5">Business Name<span class="text-red-500">*</span></label>
                                    <input type="text" placeholder="Enter your business name" class="w-full h-11 px-3 py-2 bg-gray-50 border border-[#d1d5db] rounded-lg text-sm text-[#333] focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition"/>
                                </div>
                                <div>
                                    <label class="block text-base font-normal text-[#182230] mb-1.5">Industry<span class="text-red-500">*</span></label>
                                    <select class="w-full h-11 px-3 py-2 bg-gray-50 border border-[#d1d5db] rounded-lg text-sm text-[#333] focus:ring-2 focus:ring-brand/20 focus:border-brand outline-none transition" required>
                                        <option value="">Select your business industry</option>
                                        <option>Automotive Services</option>
                                        <option>Construction &amp; Trades</option>
                                        <option>Financial Services</option>
                                        <option>Health &amp; Wellness</option>
                                        <option>Legal</option>
                                        <option>Medical &amp; Healthcare</option>
                                        <option>Professional Services</option>
                                        <option>Technology &amp; IT</option>
                                        <option>Tourism &amp; Hospitality</option>
                                        <option>Other</option>
                                    </select>
                                </div>
                                <button type="submit" class="w-full py-[14.4px] px-5 bg-[#2b84b4] text-white text-sm font-semibold rounded-lg hover:bg-brand-dark transition-all duration-300">
                                    Get Sophiie to Call Me
                                </button>
                                <p class="text-xs text-center text-gray-400">No credit card required. No obligation. Just results.</p>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right: Phone Image -->
            <div class="lg:w-1/2 flex justify-center">
                <img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68f1df5d8132b99ef29e1c49_received-ph-image.webp" alt="Sophiie calling demo" class="w-[335px] h-auto object-contain"/>
            </div>
        </div>
    </div>
</section>

<!-- ============ WHAT CAN SOPHIIE DO (TABS) ============ -->
<section class="pt-20 pb-[100px]" x-data="{ activeTab: 0, shown: true }">
    <div class="max-w-[1140px] mx-auto px-3">
        <!-- Header -->
        <div class="text-center mb-12 max-w-[670px] mx-auto">
            <h2 class="text-[36px] font-semibold text-[#1f2937] leading-[39.6px] mb-[25px]">What Can Sophiie Run<br/>Your Entire Office?</h2>
            <p class="text-base text-[#4b5563] leading-6">Sophiie takes care of the day-to-day reception tasks, making life easier for you and your team.</p>
        </div>

        <!-- Tab Pill Bar -->
        <div class="relative mb-[88px] flex justify-center">
            <div id="tabBar" class="bg-[#f7fbfe] border border-[#d7edf9] rounded-2xl px-1 inline-flex items-center relative" style="height: 66px;">
                <div id="tabSlider" class="absolute h-[50px] bg-[#2b84b4] rounded-md" style="z-index: 0; top: 50%; transform: translateY(-50%); transition: left 0.3s, width 0.3s; opacity: 0;"></div>
                <button data-tab="0" @click="activeTab = 0; shown = false; setTimeout(() => shown = true, 50)" :class="activeTab === 0 ? 'text-white' : 'text-[#4b5563]'" class="tab-btn text-white relative z-10 px-3.5 py-4 text-base font-medium transition-colors duration-200 whitespace-nowrap">Answers Calls</button>
                <button data-tab="1" @click="activeTab = 1; shown = false; setTimeout(() => shown = true, 50)" :class="activeTab === 1 ? 'text-white' : 'text-[#4b5563]'" class="tab-btn text-[#4b5563] relative z-10 px-3.5 py-4 text-base font-medium transition-colors duration-200 whitespace-nowrap">Responds to Emails</button>
                <button data-tab="2" @click="activeTab = 2; shown = false; setTimeout(() => shown = true, 50)" :class="activeTab === 2 ? 'text-white' : 'text-[#4b5563]'" class="tab-btn text-[#4b5563] relative z-10 px-3.5 py-4 text-base font-medium transition-colors duration-200 whitespace-nowrap">Responds to Texts</button>
                <button data-tab="3" @click="activeTab = 3; shown = false; setTimeout(() => shown = true, 50)" :class="activeTab === 3 ? 'text-white' : 'text-[#4b5563]'" class="tab-btn text-[#4b5563] relative z-10 px-3.5 py-4 text-base font-medium transition-colors duration-200 whitespace-nowrap">Chatbot</button>
                <button data-tab="4" @click="activeTab = 4; shown = false; setTimeout(() => shown = true, 50)" :class="activeTab === 4 ? 'text-white' : 'text-[#4b5563]'" class="tab-btn text-[#4b5563] relative z-10 px-3.5 py-4 text-base font-medium transition-colors duration-200 whitespace-nowrap">Jobs</button>
                <button data-tab="5" @click="activeTab = 5; shown = false; setTimeout(() => shown = true, 50)" :class="activeTab === 5 ? 'text-white' : 'text-[#4b5563]'" class="tab-btn text-[#4b5563] relative z-10 px-3.5 py-4 text-base font-medium transition-colors duration-200 whitespace-nowrap">Customer CRM</button>
            </div>
        </div>
        <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
            var bar = document.getElementById('tabBar');
            var slider = document.getElementById('tabSlider');
            var btns = bar.querySelectorAll('.tab-btn');
