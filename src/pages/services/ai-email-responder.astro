---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const features = [
    { title: 'Fast and Friendly Responses', desc: 'Need a reply in seconds? Sophiie drafts emails with lightning speed, customised to reflect your brand\'s unique tone and style.', lottie: 'https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e75d0949229cd0fba49323_anim7.json' },
    { title: 'Writes Like Magic', desc: 'Tell Sophiie what you want to say, and she\'ll craft the perfect email for you—no fuss, no hassle.', lottie: 'https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e75d0a26ac722435526ba0_anim10.json' },
    { title: 'Knowledge-Based Replies', desc: 'Sophiie taps into your business\'s knowledge base to deliver accurate, informed responses that showcase your expertise.', lottie: 'https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e75d0a7774dc0c6d4b178f_anim8.json' },
    { title: 'Attachment Library', desc: 'Upload frequently used documents, forms, or brochures, and Sophiie will include them in emails as needed—no more digging around your computer.', lottie: 'https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e75d0aa18d0ed5035083bb_anim9.json' },
];

const whyChoose = [
    { title: 'Always Responsive', desc: 'Sophiie keeps your business connected, even during peak times or after hours.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee233200674d6e75325fec_icon9.png' },
    { title: 'Customised Replies', desc: 'Personalised responses reflect your business\'s tone, whether formal, casual, or friendly.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee234cfb32ffc9bebcfee4_icon16.png' },
    { title: 'Time Saver', desc: 'Focus on what matters most while Sophiie handles the day-to-day email grind.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee2364e02dd50f14f82e2c_icon7.png' },
    { title: 'Professional Every Time', desc: 'No typos, no missed information—just polished, professional replies.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee237db3788dbdcf3024f8_icon3.png' },
    { title: 'Seamless Integration', desc: 'Sophiie syncs with your email, ensuring replies are sent accurately.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee2394697870252b1a2a64_icon8.png' },
];

const faqs = [
    { q: 'How does Sophiie\'s email responder work?', a: 'Sophiie connects to your email, reads incoming messages, and drafts intelligent replies based on your business knowledge base and tone preferences.' },
    { q: 'Can I connect my existing email to Sophiie?', a: 'Yes. Sophiie integrates with Gmail, Outlook, and other popular email platforms for seamless connectivity.' },
    { q: 'Can I manage multiple email threads within the Sophiie dashboard?', a: 'Absolutely. Sophiie\'s unified inbox lets you view, manage, and respond to all email threads from one central dashboard.' },
    { q: 'Does Sophiie suggest responses for emails?', a: 'Yes. Sophiie analyses the incoming message and suggests contextually appropriate replies that you can send with one click or edit first.' },
    { q: 'Can I reply to emails directly from Sophiie?', a: 'Yes. You can compose, reply, and forward emails directly from the Sophiie dashboard without switching apps.' },
    { q: 'Does Sophiie support multiple email integrations?', a: 'Yes. You can connect multiple email accounts and manage them all from a single Sophiie dashboard.' },
];

const solutions = [
    { title: 'AI Phone Answering', desc: 'Never miss a call again—Sophiie answers, qualifies leads, and routes inquiries seamlessly.', href: '/services/ai-phone-answering' },
    { title: 'AI Chatbot', desc: 'Engage website visitors instantly with an AI chatbot that answers questions and captures leads.', href: '/services/ai-chatbot' },
];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>AI Email Responder | Sophiie AI</title>
    <meta name="description" content="Sophiie handles enquiries, sends updates, and follows up—so you stay professional, responsive, and never ghost a customer again."/>

    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>

    <script is:inline defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Geist', 'Inter', 'sans-serif'] },
                    colors: { brand: { 50: '#eef8ff', 100: '#d9efff', light: '#9adcff', DEFAULT: '#36a5e1', dark: '#2b84b4', navy: '#081245' } }
                }
            }
        }
    </script>

    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.12.2/lottie.min.js"></script>

    <style is:global>
        [x-cloak] { display: none !important; }
        .nav-dropdown { position: static; }
        .nav-dropdown .nav-dropdown-menu { display: block; opacity: 0; visibility: hidden; pointer-events: none; transition: 0.3s; position: absolute; top: 100%; left: 0; right: 0; padding-top: 30px; }
        .nav-dropdown:hover .nav-dropdown-menu { opacity: 1; visibility: visible; pointer-events: auto; }
        .nav-dropdown:hover .nav-dropdown-arrow { transform: rotate(180deg); }
        .nav-dropdown-arrow { transition: transform 0.3s ease-in-out; }
    </style>
</head>
<body class="font-sans text-[#475467] antialiased bg-white overflow-x-hidden" x-data="{ mobileMenuOpen: false, scrolled: false, activeFaq: 0 }" @scroll.window="scrolled = (window.scrollY > 20)">

<Header />

<!-- Background SVG spanning hero + meet + features -->
<div class="relative">
<img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e4bb3b79d1daf24cb8e700_bg-hero.svg" alt="" class="absolute top-0 left-0 w-full" style="z-index: -1; height: auto; pointer-events: none;"/>

<!-- ============ HERO BANNER ============ -->
<section style="padding: 100px 0 35px;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="flex flex-col lg:flex-row items-center">
            <!-- Left: Text -->
            <div style="width: 558px; flex-shrink: 0;">
                <div style="height: 520px; display: flex; flex-direction: column; justify-content: center;">
                    <h1 class="text-[48px] font-bold text-[#182230] leading-[52.8px] mb-4">AI Email Responder</h1>
                    <h2 class="text-[32px] font-bold text-[#475467] leading-[36px] mb-2.5">Automated AI Email Responses That Reply to Customers Instantly</h2>
                    <p class="text-lg text-[#1f2937] leading-[27px] mb-6">Sophiie handles enquiries, sends updates, and follows up—so you stay professional, responsive, and never ghost a customer again.</p>
                    <div>
                        <a href="/free-demo-alt" class="inline-flex items-center px-5 py-[14.5px] bg-[#2b84b4] text-white font-semibold rounded-[10px] hover:bg-brand-dark transition-all text-base">Learn More</a>
                    </div>
                </div>
            </div>
            <!-- Right: Image (z9) + Lottie (behind) + Blur (bottom) -->
            <div style="width: 558px; height: 520px; flex-shrink: 0; position: relative; z-index: 1;">
                <!-- Static image - on top, object-fit: contain preserves aspect ratio -->
                <img src="https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee1e6bc28c8b8528214698_hero-ae.png" alt="AI Email Responder" style="position: absolute; top: 0; left: 0; z-index: 9; width: 558px; height: 522px; object-fit: contain; max-width: 100%; max-height: 100%;"/>
                <!-- Blur glow - behind everything -->
                <img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e61bed02cf3c50548201d1_hero-blur.png" alt="" style="position: absolute; top: 260px; left: 0; width: 558px; height: 520px; z-index: -1; pointer-events: none;"/>
                <!-- Lottie animation - middle layer, animates behind the image -->
                <div style="position: relative; width: 558px; height: 520px;">
                    <div style="width: 493px; height: 520px; margin: 0 32.5px;" id="hero-lottie" data-lottie-path="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e75d0a26ac722435526ba0_anim10.json"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============ MEET SOPHIIE ============ -->
<section style="padding: 0;">
    <div class="max-w-[1140px] mx-auto px-3">
        <!-- Header -->
        <div class="text-center mb-12" style="padding-top: 96px;">
            <h2 class="text-[48px] font-semibold text-[#1e2939] leading-[57.6px] mb-4">Meet Sophiie, Your Email Reply Extraordinaire</h2>
            <p class="text-lg text-[#4b5563] leading-[27px] max-w-[700px] mx-auto">Say goodbye to delayed responses and overflowing inboxes. Sophiie, your AI-powered email assistant, ensures your business stays responsive and professional, crafting perfect replies tailored to every customer.</p>
        </div>
        <!-- Image -->
        <div class="flex justify-center">
            <img src="https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68f77f1b5da7b08e91b99ac3_68ee1e9f54d64e9b4b11e353_ae-img0-p-1600.webp" alt="Sophiie Email Dashboard" style="width: 1024px; height: 685px; object-fit: contain;"/>
        </div>
    </div>
</section>

<!-- ============ FEATURES (4 ALTERNATING) ============ -->
<section style="padding: 96px 0 120px;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="text-center mb-16">
            <h2 class="text-[36px] font-semibold text-[#182230] leading-[46.8px]">What Can Sophiie Do on Your Website?</h2>
        </div>

        <div class="space-y-20">
            {features.map((feature, idx) => (
                <div class={`flex flex-col lg:flex-row items-center gap-12 ${idx % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
                    <div class="lg:w-1/2">
                        <h3 class="text-[30px] font-semibold text-[#182230] leading-[36px] mb-4">{feature.title}</h3>
                        <p class="text-base text-[#4b5563] leading-6">{feature.desc}</p>
                    </div>
                    <div class="lg:w-1/2">
                        <div class="rounded-[40px] overflow-hidden" style="height: 400px;" id={`feature-lottie-${idx}`} data-lottie-path={feature.lottie}></div>
                    </div>
                </div>
            ))}
        </div>
        <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('[data-lottie-path]').forEach(function(el) {
                lottie.loadAnimation({
                    container: el,
                    renderer: 'svg',
                    loop: true,
                    autoplay: true,
                    path: el.getAttribute('data-lottie-path')
                });
            });
        });
        </script>
    </div>
</section>

</div><!-- end background SVG wrapper -->

<!-- ============ READY TO MEET SOPHIIE (CTA 1) ============ -->
<section style="padding: 110px 0 64px;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="flex flex-col lg:flex-row items-center gap-12">
            <div class="lg:w-[55%]">
                <h2 class="text-[36px] font-semibold text-[#182230] leading-[39.6px] mb-4">Ready to Meet Sophiie?</h2>
                <p class="text-base text-[#4b5563] leading-6 mb-6">Meet your AI Office Manager—designed to keep your business running smoothly while you stay focused on the big picture. From managing enquiries and bookings to keeping your team and customers in sync, Sophiie does it all.</p>
                <a href="/free-demo-alt" class="inline-flex items-center px-5 py-[14.5px] bg-white text-[#182230] font-semibold rounded-[10px] border border-[#d1d5db] hover:bg-gray-50 transition-all text-base">Learn More</a>
            </div>
            <div class="lg:w-[45%]">
                <img src="https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68f77f23b83572778915737f_68ee516adbc82e5636fdf252_ae-img1.webp" alt="Sophiie Email" class="w-full h-auto rounded-2xl"/>
            </div>
        </div>
    </div>
</section>

<!-- ============ WHY CHOOSE ============ -->
<section class="bg-[#f9fafc]" style="padding: 120px 0 96px;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="text-center mb-14">
            <h2 class="text-[36px] font-semibold text-[#182230] leading-[43.2px]">Why Choose Sophiie for Your Emails?</h2>
        </div>

        <div class="flex flex-wrap justify-center gap-6">
            {whyChoose.map(card => (
                <div class="bg-white rounded-xl p-6 text-center" style="width: 352px; min-height: 195px;">
                    <div class="w-12 h-12 mx-auto mb-4">
                        <img src={card.img} alt={card.title} class="w-full h-full object-contain"/>
                    </div>
                    <h3 class="text-xl font-semibold text-[#182230] leading-6 mb-2">{card.title}</h3>
                    <p class="text-sm text-[#4b5563] leading-[21px]">{card.desc}</p>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ============ SMART SOLUTIONS ============ -->
<section style="padding: 96px 0 0;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="mb-10">
            <h2 class="text-[36px] font-semibold text-[#182230] leading-[39.6px] mb-3">Explore More Smart Solutions</h2>
            <p class="text-base text-[#4b5563] leading-6">Discover additional tools that work seamlessly with Sophiie to elevate your customer communication experience.</p>
        </div>

        <div class="flex flex-col lg:flex-row">
            <!-- Left: Cards -->
            <div style="width: 558px; flex-shrink: 0;" class="space-y-6 flex flex-col justify-center">
                {solutions.map(sol => (
                    <div class="pb-6 border-b border-gray-100">
                        <h3 class="text-lg font-semibold text-[#101828] leading-[21.6px] mb-1">{sol.title}</h3>
                        <p class="text-sm text-[#4b5563] leading-[21px] mb-2">{sol.desc}</p>
                        <a href={sol.href} class="text-sm font-semibold text-brand hover:underline">Learn more</a>
                    </div>
                ))}
            </div>
            <!-- Right: Image -->
            <div style="width: 558px; flex-shrink: 0;">
                <img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e63aa2a8934b30b9cc82fa_explore.webp" alt="Explore Smart Solutions" style="width: 558px; height: 516px; object-fit: contain;"/>
            </div>
        </div>
    </div>
</section>

<!-- ============ FAQ ============ -->
<section style="padding: 80px 0;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="flex flex-col lg:flex-row gap-16">
            <div class="lg:w-[45%]">
                <h2 class="text-[36px] font-semibold text-[#182230] leading-[39.6px] mb-4">Frequently asked questions</h2>
                <p class="text-base text-[#4b5563] leading-6">Find quick answers to common questions about Sophiie's AI email responder.</p>
            </div>
            <div class="lg:w-[55%] space-y-3">
                {faqs.map((faq, idx) => (
                    <div class="bg-gray-50 border border-gray-100 rounded-xl overflow-hidden">
                        <button @click={`activeFaq = activeFaq === ${idx} ? null : ${idx}`} class="w-full flex justify-between items-center p-5 text-left">
                            <span class="font-medium text-[#111827] text-lg leading-[28px] pr-4">{faq.q}</span>
                            <svg class="w-5 h-5 text-brand flex-shrink-0 transition-transform" :class={`{ 'rotate-180': activeFaq === ${idx} }`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </button>
                        <div x-show={`activeFaq === ${idx}`} x-collapse x-cloak class="px-5 pb-5 text-gray-500 text-sm leading-relaxed">
                            {faq.a}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

<!-- ============ BOTTOM CTA ============ -->
<section style="padding: 80px 0;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="rounded-2xl text-center" style="background: linear-gradient(to right, #7dd3ff 0%, #4aa9ff 100%); padding: 75px 64px;">
            <h2 class="text-[36px] font-semibold text-white leading-[39.6px] mb-4">Ready to Let Sophiie Handle Your Emails?</h2>
            <p class="text-lg text-white leading-[27px] max-w-[600px] mx-auto mb-8">Discover how Sophiie can turn your inbox into a well-oiled machine. Try her today and experience AI-powered email efficiency at its best!</p>
            <a href="/free-demo-alt" class="inline-flex items-center px-5 py-[15.5px] bg-white text-[#182230] text-base font-semibold rounded-[10px] border border-[#d1d5db] hover:bg-gray-50 transition-all">Learn More</a>
        </div>
    </div>
</section>

<Footer />

</body>
</html>
