---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const features = [
    { title: 'Answering FAQs', desc: 'Visitors get instant answers to common questions, from pricing to service details.', lottie: 'https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e51c514df0de8c143052ae_anim1.json' },
    { title: 'Booking Appointments', desc: 'Sophiie can guide customers through the booking process seamlessly.', lottie: 'https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e75d0951338cca4e47b9c5_anim2.json' },
    { title: 'Collecting Enquiries', desc: 'Capture leads by gathering names, emails, and service needs in real-time.', lottie: 'https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e75d29f19bd6969811e4a8_anim20.json' },
    { title: 'Redirecting Complex Queries', desc: 'When a human touch is needed, Sophiie flags enquiries for your team to follow up.', lottie: 'https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e75d09863753a2feb426a2_anim3.json' },
];

const whyChoose = [
    { title: 'Knowledge Hub Integration', desc: 'Sophiie pulls information directly from your centralised knowledge base, ensuring responses are accurate.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee34b1c11de1624e071c0a_icon10.png' },
    { title: 'Customised Responses', desc: 'Every interaction reflects your business\'s unique voice and values.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee34da008f19fb97074932_icon6.png' },
    { title: 'Always Available', desc: 'Sophiie works 24/7, making sure your website visitors are never left waiting.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee35026fa457fc11dde858_icon12.png' },
    { title: 'User-Friendly Installation', desc: 'Setting up Sophiie on your website is quick, simple, and hassle-free.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee2f4c29ef9cd689c76e06_icon14.png' },
    { title: 'Lead Capture Made Easy', desc: 'Sophiie collects visitor details and enquiries, sending them straight to your dashboard for follow-up.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee35586d9b37aad1b6ab8b_icon18.png' },
];

const faqs = [
    { q: 'How does Sophiie\'s chatbot handle customer enquiries?', a: 'Sophiie uses your knowledge base to provide instant, accurate answers to visitor questions on your website.' },
    { q: 'Can Sophiie\'s chatbot help reduce my workload?', a: 'Yes. By handling FAQs, booking requests, and lead capture automatically, Sophiie frees up your time for higher-value tasks.' },
    { q: 'Can I customise the chatbot\'s responses?', a: 'Absolutely. You can train Sophiie with your own knowledge base and set the tone to match your brand.' },
    { q: 'Where does the chatbot store conversations and customer details?', a: 'All conversations and captured details are stored securely in your Sophiie dashboard for easy access and follow-up.' },
    { q: 'Can Sophiie handle after-hours and weekend enquiries?', a: 'Yes. Sophiie works 24/7 so your website visitors always get a response, no matter when they visit.' },
];

const solutions = [
    { title: 'AI Phone Answering', desc: 'Never miss a call again—Sophiie answers, qualifies leads, and routes inquiries seamlessly.', href: '/services/ai-phone-answering' },
    { title: 'AI Email Responder', desc: 'Let Sophiie handle your email inquiries with speed and precision, keeping your inbox organised.', href: '/services/ai-email-responder' },
    { title: 'AI Text Messaging', desc: 'Reach your customers on the go with personalised text responses—because quick replies matter.', href: '/services/ai-text-messaging' },
];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>AI Chatbot | Sophiie AI</title>
    <meta name="description" content="Sophiie chats with website visitors, answers questions, books jobs, and captures leads—even while you're asleep."/>

    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>

    <script is:inline defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Geist', 'Inter', 'sans-serif'] },
                    colors: { brand: { 50: '#eef8ff', 100: '#d9efff', light: '#9adcff', DEFAULT: '#36a5e1', dark: '#2b84b4', navy: '#081245' } }
                }
            }
        }
    </script>

    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.12.2/lottie.min.js"></script>

    <style is:global>
        [x-cloak] { display: none !important; }
        .nav-dropdown { position: static; }
        .nav-dropdown .nav-dropdown-menu { display: block; opacity: 0; visibility: hidden; pointer-events: none; transition: 0.3s; position: absolute; top: 100%; left: 0; right: 0; padding-top: 30px; }
        .nav-dropdown:hover .nav-dropdown-menu { opacity: 1; visibility: visible; pointer-events: auto; }
        .nav-dropdown:hover .nav-dropdown-arrow { transform: rotate(180deg); }
        .nav-dropdown-arrow { transition: transform 0.3s ease-in-out; }
    </style>
</head>
<body class="font-sans text-[#475467] antialiased bg-white overflow-x-hidden" x-data="{ mobileMenuOpen: false, scrolled: false, activeFaq: 0 }" @scroll.window="scrolled = (window.scrollY > 20)">

<Header />

<!-- Background SVG spanning hero + meet + features -->
<div class="relative">
<img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e4bb3b79d1daf24cb8e700_bg-hero.svg" alt="" class="absolute top-0 left-0 w-full" style="z-index: -1; height: auto; pointer-events: none;"/>

<!-- ============ HERO BANNER ============ -->
<section style="padding: 100px 0 35px;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="flex flex-col lg:flex-row items-center">
            <!-- Left: Text -->
            <div style="width: 558px; flex-shrink: 0;">
                <div style="height: 520px; display: flex; flex-direction: column; justify-content: center;">
                    <h1 class="text-[48px] font-bold text-[#182230] leading-[52.8px] mb-4">AI Chat Bot</h1>
                    <h2 class="text-[32px] font-bold text-[#475467] leading-[36px] mb-2.5">An AI Chat Bot That Automates Customer Conversations 24/7</h2>
                    <p class="text-lg text-[#1f2937] leading-[27px] mb-6">Sophiie chats with website visitors, answers questions, books jobs, and captures leads—even while you're asleep.</p>
                    <div>
                        <a href="/free-demo-alt" class="inline-flex items-center px-5 py-[14.5px] bg-[#2b84b4] text-white font-semibold rounded-[10px] hover:bg-brand-dark transition-all text-base">Learn More</a>
                    </div>
                </div>
            </div>
            <!-- Right: Image (z9) + Lottie (behind) + Blur (bottom) -->
            <div style="width: 558px; height: 520px; flex-shrink: 0; position: relative; z-index: 1;">
                <!-- Static image - on top, object-fit: contain preserves aspect ratio -->
                <img src="https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee2fedc14f34e8918fc4b1_hero-ac.png" alt="AI Chatbot" style="position: absolute; top: 0; left: 0; z-index: 9; width: 558px; height: 522px; object-fit: contain; max-width: 100%; max-height: 100%;"/>
                <!-- Blur glow - behind everything -->
                <img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e61bed02cf3c50548201d1_hero-blur.png" alt="" style="position: absolute; top: 260px; left: 0; width: 558px; height: 520px; z-index: -1; pointer-events: none;"/>
                <!-- Lottie animation - middle layer, animates behind the image -->
                <div style="position: relative; width: 558px; height: 520px;">
                    <div style="width: 493px; height: 520px; margin: 0 32.5px;" id="hero-lottie" data-lottie-path="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e75d0987eb714a42499275_anim4.json"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============ MEET SOPHIIE ============ -->
<section style="padding: 0;">
    <div class="max-w-[1140px] mx-auto px-3">
        <!-- Header -->
        <div class="text-center mb-12" style="padding-top: 96px;">
            <h2 class="text-[48px] font-semibold text-[#1e2939] leading-[57.6px] mb-4">Sophiie, the Chatbot That Never Sleeps</h2>
            <p class="text-lg text-[#4b5563] leading-[27px] max-w-[700px] mx-auto">Bring your website to life with Sophiie, your dedicated AI chatbot. Designed to seamlessly integrate with your website, Sophiie ensures every visitor gets the information they need—instantly and accurately.</p>
        </div>
        <!-- Image -->
        <div class="flex justify-center">
            <img src="https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68f77f1b5da7b08e91b99ac3_68ee30acc12c63b6b70df794_ac-img0-p-1600.webp" alt="Sophiie Chatbot Dashboard" style="width: 1024px; height: 685px; object-fit: contain;"/>
        </div>
    </div>
</section>

<!-- ============ FEATURES (4 ALTERNATING) ============ -->
<section style="padding: 96px 0 120px;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="text-center mb-16">
            <h2 class="text-[36px] font-semibold text-[#182230] leading-[46.8px]">What Can Sophiie Do on Your Website?</h2>
        </div>

        <div class="space-y-20">
            {features.map((feature, idx) => (
                <div class={`flex flex-col lg:flex-row items-center gap-12 ${idx % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
                    <div class="lg:w-1/2">
                        <h3 class="text-[30px] font-semibold text-[#182230] leading-[36px] mb-4">{feature.title}</h3>
                        <p class="text-base text-[#4b5563] leading-6">{feature.desc}</p>
                    </div>
                    <div class="lg:w-1/2">
                        <div class="rounded-[40px] overflow-hidden" style="height: 400px;" id={`feature-lottie-${idx}`} data-lottie-path={feature.lottie}></div>
                    </div>
                </div>
            ))}
        </div>
        <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('[data-lottie-path]').forEach(function(el) {
                lottie.loadAnimation({
                    container: el,
                    renderer: 'svg',
                    loop: true,
                    autoplay: true,
                    path: el.getAttribute('data-lottie-path')
                });
            });
        });
        </script>
    </div>
</section>

</div><!-- end background SVG wrapper -->

<!-- ============ READY TO MEET SOPHIIE (CTA 1) ============ -->
<section style="padding: 110px 0 64px;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="flex flex-col lg:flex-row items-center gap-12">
            <div class="lg:w-[55%]">
                <h2 class="text-[36px] font-semibold text-[#182230] leading-[39.6px] mb-4">Ready to Meet Sophiie?</h2>
                <p class="text-base text-[#4b5563] leading-6 mb-6">Meet your AI Office Manager—designed to keep your business running smoothly while you stay focused on the big picture. From managing enquiries and bookings to keeping your team and customers in sync, Sophiie does it all.</p>
                <a href="/free-demo-alt" class="inline-flex items-center px-5 py-[14.5px] bg-white text-[#182230] font-semibold rounded-[10px] border border-[#d1d5db] hover:bg-gray-50 transition-all text-base">Learn More</a>
            </div>
            <div class="lg:w-[45%]">
                <img src="https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68f77f23b83572778915737f_68ee52a2c28c8b8528355652_ac-img1.webp" alt="Sophiie Chatbot" class="w-full h-auto rounded-2xl"/>
            </div>
        </div>
    </div>
</section>

<!-- ============ WHY CHOOSE ============ -->
<section class="bg-[#f9fafc]" style="padding: 120px 0 96px;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="text-center mb-14">
            <h2 class="text-[36px] font-semibold text-[#182230] leading-[43.2px]">Why Sophiie is the Chatbot You've Been Waiting For</h2>
        </div>

        <div class="flex flex-wrap justify-center gap-6">
            {whyChoose.map(card => (
                <div class="bg-white rounded-xl p-6 text-center" style="width: 352px; min-height: 195px;">
                    <div class="w-12 h-12 mx-auto mb-4">
                        <img src={card.img} alt={card.title} class="w-full h-full object-contain"/>
                    </div>
                    <h3 class="text-xl font-semibold text-[#182230] leading-6 mb-2">{card.title}</h3>
                    <p class="text-sm text-[#4b5563] leading-[21px]">{card.desc}</p>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ============ SMART SOLUTIONS ============ -->
<section style="padding: 96px 0 0;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="mb-10">
            <h2 class="text-[36px] font-semibold text-[#182230] leading-[39.6px] mb-3">Explore More Smart Solutions</h2>
            <p class="text-base text-[#4b5563] leading-6">Discover additional tools that work seamlessly with Sophiie to elevate your customer communication experience.</p>
        </div>

        <div class="flex flex-col lg:flex-row">
            <!-- Left: Cards -->
            <div style="width: 558px; flex-shrink: 0;" class="space-y-6 flex flex-col justify-center">
                {solutions.map(sol => (
                    <div class="pb-6 border-b border-gray-100">
                        <h3 class="text-lg font-semibold text-[#101828] leading-[21.6px] mb-1">{sol.title}</h3>
                        <p class="text-sm text-[#4b5563] leading-[21px] mb-2">{sol.desc}</p>
                        <a href={sol.href} class="text-sm font-semibold text-brand hover:underline">Learn more</a>
                    </div>
                ))}
            </div>
            <!-- Right: Image -->
            <div style="width: 558px; flex-shrink: 0;">
                <img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e63aa2a8934b30b9cc82fa_explore.webp" alt="Explore Smart Solutions" style="width: 558px; height: 516px; object-fit: contain;"/>
            </div>
        </div>
    </div>
</section>

<!-- ============ FAQ ============ -->
<section style="padding: 80px 0;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="flex flex-col lg:flex-row gap-16">
            <div class="lg:w-[45%]">
                <h2 class="text-[36px] font-semibold text-[#182230] leading-[39.6px] mb-4">Frequently asked questions</h2>
                <p class="text-base text-[#4b5563] leading-6">Find quick answers to common questions about Sophiie's AI chatbot.</p>
            </div>
            <div class="lg:w-[55%] space-y-3">
                {faqs.map((faq, idx) => (
                    <div class="bg-gray-50 border border-gray-100 rounded-xl overflow-hidden">
                        <button @click={`activeFaq = activeFaq === ${idx} ? null : ${idx}`} class="w-full flex justify-between items-center p-5 text-left">
                            <span class="font-medium text-[#111827] text-lg leading-[28px] pr-4">{faq.q}</span>
                            <svg class="w-5 h-5 text-brand flex-shrink-0 transition-transform" :class={`{ 'rotate-180': activeFaq === ${idx} }`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </button>
                        <div x-show={`activeFaq === ${idx}`} x-collapse x-cloak class="px-5 pb-5 text-gray-500 text-sm leading-relaxed">
                            {faq.a}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

<!-- ============ BOTTOM CTA ============ -->
<section style="padding: 80px 0;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="rounded-2xl text-center" style="background: linear-gradient(to right, #7dd3ff 0%, #4aa9ff 100%); padding: 75px 64px;">
            <h2 class="text-[36px] font-semibold text-white leading-[39.6px] mb-4">Get Sophiie on Your Website Today</h2>
            <p class="text-lg text-white leading-[27px] max-w-[600px] mx-auto mb-8">Discover how Sophiie's AI chatbot can transform your website into an interactive, customer-friendly hub. Let Sophiie do the talking while you focus on growing your business!</p>
            <a href="/free-demo-alt" class="inline-flex items-center px-5 py-[15.5px] bg-white text-[#182230] text-base font-semibold rounded-[10px] border border-[#d1d5db] hover:bg-gray-50 transition-all">Learn More</a>
        </div>
    </div>
</section>

<Footer />

</body>
</html>
