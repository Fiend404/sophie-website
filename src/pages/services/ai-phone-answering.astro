---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const features = [
    { title: 'Friendly Greetings', desc: 'Sophiie greets every caller with a customised script that reflects your brand\'s tone and personality.', lottie: 'https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e75d29c4f3cb86166e1d29_anim19.json' },
    { title: 'Lead Capturing Pro', desc: 'She gathers essential details from callers, like names, contact info, and service needs, so you never miss an opportunity.', lottie: 'https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e75d29f19bd6969811e4a8_anim20.json' },
    { title: 'Efficient Call Handling', desc: 'Whether it\'s booking appointments, answering FAQs, or taking messages, Sophiie gets it done without breaking a sweat.', lottie: 'https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e75d29886a402e24e69268_anim21.json' },
    { title: 'Real-Time Call Summaries', desc: 'She sends detailed summaries straight to your inbox or CRM, so you always know what\'s happening.', lottie: 'https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e75d2acf515b19fb2b9d0a_anim22.json' },
];

const whyChoose = [
    { title: 'AI Solutions for Tradies in Australia', desc: 'For tradies on the go, Sophiie ensures every job enquiry is captured.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee496ce02dd50f1404fe0f_icon21.png' },
    { title: 'AI Solutions in Medical & Healthcare Industry', desc: 'From booking patient appointments to answering common queries, Sophiie keeps things running smoothly.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee49f8a349866d6ed097b7_icon27.png' },
    { title: 'AI Solutions in Professional Services Industry', desc: 'Lawyers, consultants, and accountants love her for her accuracy and professionalism.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee4a0f2862480f0cf3d0c3_icon15.png' },
    { title: 'AI Solutions in Financial Industry', desc: 'Sophiie manages client calls and ensures no financial question goes unanswered.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee49a47431f6c08f5e6e34_icon19.png' },
    { title: 'AI Solutions in Health & Wellness Industry', desc: 'From gyms to massage therapists, Sophiie schedules appointments and answers customer inquiries.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee3a37b04b0de2bce8b39a_icon4.png' },
    { title: 'AI Solutions in Automotive Industry', desc: 'Sophiie manages bookings for repairs, servicing, and test drives.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee4987a26cf349ef86780f_icon17.png' },
    { title: 'AI Solutions in Technology & IT Industry', desc: 'Sophiie fields customer support queries and schedules tech service calls.', img: 'https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68ee4a27ea5eee4e74cb74bf_icon30.png' },
];

const faqs = [
    { q: 'How does Sophiie\'s AI Receptionist answer calls?', a: 'Sophiie picks up calls instantly with a customised greeting, gathers caller details, and handles enquiries based on your business rules and knowledge base.' },
    { q: 'Can Sophiie handle multiple calls at once?', a: 'Yes. Sophiie can handle up to 10,000 simultaneous calls, so no customer ever gets a busy signal.' },
    { q: 'Can I customise the way Sophiie answers calls?', a: 'Absolutely. You can set custom greetings, call flows, FAQ responses, and escalation rules to match your brand.' },
    { q: 'Does Sophiie work after hours and on weekends?', a: 'Yes. Sophiie is available 24/7/365, ensuring your business never misses a call regardless of the time.' },
    { q: 'Can Sophiie send call summaries or messages to my team?', a: 'Yes. After every call, Sophiie sends detailed summaries via email, SMS, or directly to your CRM.' },
    { q: 'Can Sophiie filter out spam and unwanted calls?', a: 'Yes. Sophiie identifies and filters spam calls so your team only deals with genuine enquiries.' },
];

const solutions = [
    { title: 'AI Email Responder', desc: 'Let Sophiie handle your email inquiries with speed and precision, keeping your inbox organised and your customers satisfied.', href: '/services/ai-email-responder' },
    { title: 'AI Text Messaging', desc: 'Reach your customers on the go with personalised text responses—because quick replies matter.', href: '/services/ai-text-messaging' },
    { title: 'Customer CRM', desc: 'Stay organised with a powerful CRM that keeps all your customer details and conversations in one place.', href: '/services/customer-crm' },
];
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1"/>
    <title>AI Phone Call Answering | Sophiie AI</title>
    <meta name="description" content="Sophiie sounds just like a real person—friendly, professional, and always ready to answer your calls 24/7."/>

    <link rel="preconnect" href="https://fonts.googleapis.com"/>
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
    <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet"/>

    <script is:inline defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
    <script is:inline defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
    <script is:inline src="https://cdn.tailwindcss.com"></script>
    <script is:inline>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Geist', 'Inter', 'sans-serif'] },
                    colors: { brand: { 50: '#eef8ff', 100: '#d9efff', light: '#9adcff', DEFAULT: '#36a5e1', dark: '#2b84b4', navy: '#081245' } }
                }
            }
        }
    </script>

    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/lottie-web/5.12.2/lottie.min.js"></script>

    <style is:global>
        [x-cloak] { display: none !important; }
        .nav-dropdown { position: static; }
        .nav-dropdown .nav-dropdown-menu { display: block; opacity: 0; visibility: hidden; pointer-events: none; transition: 0.3s; position: absolute; top: 100%; left: 0; right: 0; padding-top: 30px; }
        .nav-dropdown:hover .nav-dropdown-menu { opacity: 1; visibility: visible; pointer-events: auto; }
        .nav-dropdown:hover .nav-dropdown-arrow { transform: rotate(180deg); }
        .nav-dropdown-arrow { transition: transform 0.3s ease-in-out; }
    </style>
</head>
<body class="font-sans text-[#475467] antialiased bg-white overflow-x-hidden" x-data="{ mobileMenuOpen: false, scrolled: false, activeFaq: 0 }" @scroll.window="scrolled = (window.scrollY > 20)">

<Header />

<!-- Background SVG spanning hero + meet + features -->
<div class="relative">
<img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e4bb3b79d1daf24cb8e700_bg-hero.svg" alt="" class="absolute top-0 left-0 w-full" style="z-index: -1; height: auto; pointer-events: none;"/>

<!-- ============ HERO BANNER ============ -->
<section style="padding: 100px 0 35px;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="flex flex-col lg:flex-row items-center">
            <!-- Left: Text -->
            <div style="width: 558px; flex-shrink: 0;">
                <div style="height: 520px; display: flex; flex-direction: column; justify-content: center;">
                    <h1 class="text-[48px] font-bold text-[#182230] leading-[52.8px] mb-4">AI Phone Answering</h1>
                    <h2 class="text-[32px] font-bold text-[#475467] leading-[36px] mb-2.5">AI-Driven Phone Answering That Handles Calls Around the Clock</h2>
                    <p class="text-lg text-[#1f2937] leading-[27px] mb-6">Sophiie sounds just like a real person—and in many cases, better! She's friendly, professional, and always ready to answer your calls.</p>
                    <div>
                        <a href="/free-demo-alt" class="inline-flex items-center px-5 py-[14.5px] bg-[#2b84b4] text-white font-semibold rounded-[10px] hover:bg-brand-dark transition-all text-base">Learn More</a>
                    </div>
                </div>
            </div>
            <!-- Right: Image (z9) + Lottie (behind) + Blur (bottom) -->
            <div style="width: 558px; height: 520px; flex-shrink: 0; position: relative; z-index: 1;">
                <!-- Static image - on top, object-fit: contain preserves aspect ratio -->
                <img src="https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68e7584d5d3bf6a2a35f7919_hero-ap.png" alt="AI Phone Answering" style="position: absolute; top: 0; left: 0; z-index: 9; width: 558px; height: 522px; object-fit: contain; max-width: 100%; max-height: 100%;"/>
                <!-- Blur glow - behind everything -->
                <img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e61bed02cf3c50548201d1_hero-blur.png" alt="" style="position: absolute; top: 260px; left: 0; width: 558px; height: 520px; z-index: -1; pointer-events: none;"/>
                <!-- Lottie animation - middle layer, animates behind the image -->
                <div style="position: relative; width: 558px; height: 520px;">
                    <div style="width: 493px; height: 520px; margin: 0 32.5px;" id="hero-lottie" data-lottie-path="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e766d5f16d02b42e460c29_animh1.json"></div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ============ MEET SOPHIIE ============ -->
<section style="padding: 0;">
    <div class="max-w-[1140px] mx-auto px-3">
        <!-- Header -->
        <div class="text-center mb-12" style="padding-top: 96px;">
            <h2 class="text-[48px] font-semibold text-[#1e2939] leading-[57.6px] mb-4">Meet Sophiie, Your 24 / 7 AI Receptionist</h2>
            <p class="text-lg text-[#4b5563] leading-[27px] max-w-[700px] mx-auto">Sophiie is here to revolutionise the way your business handles phone calls. Whether you're on the tools, in a meeting, or simply need an extra hand, Sophiie steps in to answer every call with professionalism and care.</p>
        </div>
        <!-- Image -->
        <div class="flex justify-center">
            <img src="https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68f77f736f3f7060a249c2ea_68e75883391282b397297a10_ap-img0-p-1600.webp" alt="Sophiie Phone Dashboard" style="width: 1024px; height: 685px; object-fit: contain;"/>
        </div>
    </div>
</section>

<!-- ============ FEATURES (4 ALTERNATING) ============ -->
<section style="padding: 96px 0 120px;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="text-center mb-16">
            <h2 class="text-[36px] font-semibold text-[#182230] leading-[46.8px]">What Can Sophiie Do for You?</h2>
        </div>

        <div class="space-y-20">
            {features.map((feature, idx) => (
                <div class={`flex flex-col lg:flex-row items-center gap-12 ${idx % 2 === 1 ? 'lg:flex-row-reverse' : ''}`}>
                    <div class="lg:w-1/2">
                        <h3 class="text-[30px] font-semibold text-[#182230] leading-[36px] mb-4">{feature.title}</h3>
                        <p class="text-base text-[#4b5563] leading-6">{feature.desc}</p>
                    </div>
                    <div class="lg:w-1/2">
                        <div class="rounded-[40px] overflow-hidden" style="height: 400px;" id={`feature-lottie-${idx}`} data-lottie-path={feature.lottie}></div>
                    </div>
                </div>
            ))}
        </div>
        <script is:inline>
        document.addEventListener('DOMContentLoaded', function() {
            document.querySelectorAll('[data-lottie-path]').forEach(function(el) {
                lottie.loadAnimation({
                    container: el,
                    renderer: 'svg',
                    loop: true,
                    autoplay: true,
                    path: el.getAttribute('data-lottie-path')
                });
            });
        });
        </script>
    </div>
</section>

</div><!-- end background SVG wrapper -->

<!-- ============ READY TO MEET SOPHIIE (CTA 1) ============ -->
<section style="padding: 110px 0 64px;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="flex flex-col lg:flex-row items-center gap-12">
            <div class="lg:w-[55%]">
                <h2 class="text-[36px] font-semibold text-[#182230] leading-[39.6px] mb-4">Ready to Meet Sophiie?</h2>
                <p class="text-base text-[#4b5563] leading-6 mb-6">Meet your AI Office Manager—designed to keep your business running smoothly while you stay focused on the big picture. From managing enquiries and bookings to keeping your team and customers in sync, Sophiie does it all.</p>
                <a href="/free-demo-alt" class="inline-flex items-center px-5 py-[14.5px] bg-white text-[#182230] font-semibold rounded-[10px] border border-[#d1d5db] hover:bg-gray-50 transition-all text-base">Learn More</a>
            </div>
            <div class="lg:w-[45%]">
                <img src="https://cdn.prod.website-files.com/68d51ee2af6bb683f056e8cd/68f77f78a0e08f16dfc68b11_68ee51323475514470fa4715_ap-img1.webp" alt="Sophiie Phone" class="w-full h-auto rounded-2xl"/>
            </div>
        </div>
    </div>
</section>

<!-- ============ WHY CHOOSE ============ -->
<section class="bg-[#f9fafc]" style="padding: 120px 0 96px;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="text-center mb-14">
            <h2 class="text-[36px] font-semibold text-[#182230] leading-[43.2px]">Industries That Love Sophiie</h2>
        </div>

        <div class="flex flex-wrap justify-center gap-6">
            {whyChoose.map(card => (
                <div class="bg-white rounded-xl p-6 text-center" style="width: 352px; min-height: 195px;">
                    <div class="w-12 h-12 mx-auto mb-4">
                        <img src={card.img} alt={card.title} class="w-full h-full object-contain"/>
                    </div>
                    <h3 class="text-xl font-semibold text-[#182230] leading-6 mb-2">{card.title}</h3>
                    <p class="text-sm text-[#4b5563] leading-[21px]">{card.desc}</p>
                </div>
            ))}
        </div>
    </div>
</section>

<!-- ============ SMART SOLUTIONS ============ -->
<section style="padding: 96px 0 0;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="mb-10">
            <h2 class="text-[36px] font-semibold text-[#182230] leading-[39.6px] mb-3">Explore More Smart Solutions</h2>
            <p class="text-base text-[#4b5563] leading-6">Discover additional tools that work seamlessly with Sophiie to elevate your customer communication experience.</p>
        </div>

        <div class="flex flex-col lg:flex-row">
            <!-- Left: Cards -->
            <div style="width: 558px; flex-shrink: 0;" class="space-y-6 flex flex-col justify-center">
                {solutions.map(sol => (
                    <div class="pb-6 border-b border-gray-100">
                        <h3 class="text-lg font-semibold text-[#101828] leading-[21.6px] mb-1">{sol.title}</h3>
                        <p class="text-sm text-[#4b5563] leading-[21px] mb-2">{sol.desc}</p>
                        <a href={sol.href} class="text-sm font-semibold text-brand hover:underline">Learn more</a>
                    </div>
                ))}
            </div>
            <!-- Right: Image -->
            <div style="width: 558px; flex-shrink: 0;">
                <img src="https://cdn.prod.website-files.com/68d290d293affc6bb3574aeb/68e63aa2a8934b30b9cc82fa_explore.webp" alt="Explore Smart Solutions" style="width: 558px; height: 516px; object-fit: contain;"/>
            </div>
        </div>
    </div>
</section>

<!-- ============ FAQ ============ -->
<section style="padding: 80px 0;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="flex flex-col lg:flex-row gap-16">
            <div class="lg:w-[45%]">
                <h2 class="text-[36px] font-semibold text-[#182230] leading-[39.6px] mb-4">Frequently asked questions</h2>
                <p class="text-base text-[#4b5563] leading-6">Find quick answers to common questions about Sophiie's AI phone answering.</p>
            </div>
            <div class="lg:w-[55%] space-y-3">
                {faqs.map((faq, idx) => (
                    <div class="bg-gray-50 border border-gray-100 rounded-xl overflow-hidden">
                        <button @click={`activeFaq = activeFaq === ${idx} ? null : ${idx}`} class="w-full flex justify-between items-center p-5 text-left">
                            <span class="font-medium text-[#111827] text-lg leading-[28px] pr-4">{faq.q}</span>
                            <svg class="w-5 h-5 text-brand flex-shrink-0 transition-transform" :class={`{ 'rotate-180': activeFaq === ${idx} }`} fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                        </button>
                        <div x-show={`activeFaq === ${idx}`} x-collapse x-cloak class="px-5 pb-5 text-gray-500 text-sm leading-relaxed">
                            {faq.a}
                        </div>
                    </div>
                ))}
            </div>
        </div>
    </div>
</section>

<!-- ============ BOTTOM CTA ============ -->
<section style="padding: 80px 0;">
    <div class="max-w-[1140px] mx-auto px-3">
        <div class="rounded-2xl text-center" style="background: linear-gradient(to right, #7dd3ff 0%, #4aa9ff 100%); padding: 75px 64px;">
            <h2 class="text-[36px] font-semibold text-white leading-[39.6px] mb-4">Ready to Meet Sophiie?</h2>
            <p class="text-lg text-white leading-[27px] max-w-[600px] mx-auto mb-8">Discover how Sophiie can transform the way you handle calls. Don't let another lead slip through the cracks—let Sophiie answer your calls with style and precision!</p>
            <a href="/free-demo-alt" class="inline-flex items-center px-5 py-[15.5px] bg-white text-[#182230] text-base font-semibold rounded-[10px] border border-[#d1d5db] hover:bg-gray-50 transition-all">Learn More</a>
        </div>
    </div>
</section>

<Footer />

</body>
</html>
